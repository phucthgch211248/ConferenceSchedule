{% extends 'base.html.twig' %}

{% block title %}Create Conference{% endblock %}

{% block body %}
    <div class="mx-auto w-full max-w-3xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-slate-900">Create Conference</h1>
            <p class="text-sm text-slate-500">Add a new conference to the schedule.</p>
        </div>

        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div>
                <label for="title" class="mb-1 block text-sm font-medium text-slate-700">Title</label>
                <input id="title" name="title" type="text" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
            </div>

            <div>
                <label for="description" class="mb-1 block text-sm font-medium text-slate-700">Description</label>
                <textarea id="description" name="description" rows="4" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2"></textarea>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                    <label for="location" class="mb-1 block text-sm font-medium text-slate-700">Location</label>
                    <input id="location" name="location" type="text" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
                </div>

                <div>
                    <label for="date" class="mb-1 block text-sm font-medium text-slate-700">Date</label>
                    <input id="date" name="date" type="date" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">
                    Save
                </button>
                <a href="{{ path('conference_index') }}" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Cancel
                </a>
            </div>
        </form>
    </div>
{% endblock %}
