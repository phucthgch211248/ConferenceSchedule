{% extends 'base.html.twig' %}

{% block title %}Conference Detail{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-emerald-950">{{ conference.title }}</h1>
            <p class="mt-1 text-sm text-emerald-700">{{ conference.description }}</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <a href="{{ path('conference_edit', {id: conference.id}) }}" class="rounded-lg bg-amber-500 px-3 py-2 text-sm font-semibold text-white transition hover:bg-amber-600">
                Edit Conference
            </a>
            <a href="{{ path('conference_index') }}" class="rounded-lg border border-emerald-300 px-3 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-50">
                Back to List
            </a>
        </div>
    </div>

    <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-emerald-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700">Location</p>
            <p class="mt-1 text-lg font-semibold text-emerald-950">{{ conference.location }}</p>
        </div>
        <div class="rounded-2xl border border-emerald-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700">Date</p>
            <p class="mt-1 text-lg font-semibold text-emerald-950">{{ conference.date ? conference.date|date('Y-m-d') : '-' }}</p>
        </div>
        <div class="rounded-2xl border border-emerald-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700">Total Sessions</p>
            <p class="mt-1 text-lg font-semibold text-emerald-950">{{ sessions|length }}</p>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-emerald-200 bg-white shadow-sm">
        <div class="border-b border-emerald-100 bg-emerald-50 px-5 py-3">
            <h2 class="text-lg font-semibold text-emerald-950">Sessions of this Conference</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-emerald-200">
                <thead class="bg-emerald-50">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Session</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Start</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">End</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Registered Users</th>
                        <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider text-emerald-800">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-emerald-100 bg-white">
                    {% for session in sessions %}
                        <tr class="transition hover:bg-emerald-50">
                            <td class="px-5 py-4 text-sm font-semibold text-emerald-950">{{ session.title }}</td>
                            <td class="px-5 py-4 text-sm text-emerald-800">{{ session.startTime ? session.startTime|date('Y-m-d H:i') : '-' }}</td>
                            <td class="px-5 py-4 text-sm text-emerald-800">{{ session.endTime ? session.endTime|date('Y-m-d H:i') : '-' }}</td>
                            <td class="px-5 py-4 text-sm">
                                <span class="rounded-full bg-emerald-100 px-2.5 py-1 font-semibold text-emerald-800">
                                    {{ sessionRegistrationCounts[session.id] ?? 0 }}
                                </span>
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('registration_register', {sessionId: session.id}) }}" class="rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-emerald-700">
                                        Register User
                                    </a>
                                    <a href="{{ path('session_edit', {id: session.id}) }}" class="rounded-lg bg-amber-500 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-amber-600">
                                        Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-5 py-10 text-center text-sm text-emerald-700">
                                No sessions found for this conference.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
