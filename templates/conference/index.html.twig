{% extends 'base.html.twig' %}

{% block title %}Conferences{% endblock %}

{% block body %}
    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-2xl font-bold text-emerald-950">Conference Management</h1>
            <p class="text-sm text-emerald-700">Manage all conference records.</p>
        </div>
        <a href="{{ path('conference_create') }}" class="inline-flex items-center justify-center rounded-lg bg-emerald-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-800">
            + Create Conference
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
            {{ message }}
        </div>
    {% endfor %}

    <div class="overflow-hidden rounded-2xl border border-emerald-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-emerald-200">
                <thead class="bg-emerald-50">
                    <tr>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Title</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Location</th>
                        <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-emerald-800">Date</th>
                        <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider text-emerald-800">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-emerald-100 bg-white">
                    {% for conference in conferences %}
                        <tr class="transition hover:bg-emerald-50">
                            <td class="px-5 py-4">
                                <p class="font-semibold text-emerald-950">{{ conference.title }}</p>
                                <p class="mt-1 text-sm text-emerald-700">{{ conference.description }}</p>
                            </td>
                            <td class="px-5 py-4 text-sm text-emerald-800">{{ conference.location }}</td>
                            <td class="px-5 py-4 text-sm">
                                <span class="rounded-full bg-emerald-100 px-2.5 py-1 font-medium text-emerald-800">
                                    {{ conference.date ? conference.date|date('Y-m-d') : '-' }}
                                </span>
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('conference_show', {id: conference.id}) }}" class="rounded-lg bg-emerald-700 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-emerald-800">
                                        Detail
                                    </a>
                                    <a href="{{ path('conference_edit', {id: conference.id}) }}" class="rounded-lg bg-amber-500 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-amber-600">
                                        Edit
                                    </a>
                                    <form method="post" action="{{ path('conference_delete', {id: conference.id}) }}" onsubmit="return confirm('Delete this conference?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_conference_' ~ conference.id) }}">
                                        <button type="submit" class="rounded-lg bg-rose-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-rose-700">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-5 py-10 text-center text-sm text-emerald-700">
                                No conferences found.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
