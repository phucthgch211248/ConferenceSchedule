{% extends 'base.html.twig' %}

{% block title %}Register Session{% endblock %}

{% block body %}
    <div class="mx-auto w-full max-w-2xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold">Register User to Session</h1>
            <p class="mt-1 text-sm text-gray-600">
                <span class="font-medium text-gray-800">{{ session.title }}</span>
                {% if session.conference %}
                    - {{ session.conference.title }}
                {% endif %}
            </p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" class="space-y-5 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <div>
                <label for="userId" class="mb-1 block text-sm font-medium text-gray-700">User</label>
                <select id="userId" name="userId" required class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm outline-none ring-blue-500 focus:ring-2">
                    <option value="">Select user</option>
                    {% for user in users %}
                        <option value="{{ user.id }}">{{ user.name }} ({{ user.email }})</option>
                    {% endfor %}
                </select>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">
                    Register
                </button>
                <a href="{{ path('session_index') }}" class="rounded-md border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
                    Back
                </a>
            </div>
        </form>
    </div>
{% endblock %}
