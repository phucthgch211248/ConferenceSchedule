{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">Upcoming Conferences</h1>
        <p class="mt-2 text-sm text-gray-600">Browse all scheduled conferences in one place.</p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {% for conference in conferences %}
            <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
                <div class="mb-3 flex items-start justify-between gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">{{ conference.title }}</h2>
                    <span class="shrink-0 rounded-full bg-blue-100 px-2.5 py-1 text-xs font-medium text-blue-700">
                        {{ conference.date ? conference.date|date('Y-m-d') : 'No date' }}
                    </span>
                </div>

                <p class="mb-4 text-sm text-gray-600">
                    {{ conference.description }}
                </p>

                <div class="mb-4 rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-700">
                    <span class="font-medium text-gray-800">Location:</span> {{ conference.location }}
                </div>

                <a href="{{ path('conference_edit', {id: conference.id}) }}" class="inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">
                    Manage Conference
                </a>
            </article>
        {% else %}
            <div class="col-span-full rounded-lg border border-dashed border-gray-300 bg-white p-8 text-center">
                <p class="text-sm text-gray-600">No conferences found.</p>
                <a href="{{ path('conference_create') }}" class="mt-3 inline-flex items-center rounded-md bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">
                    Create your first conference
                </a>
            </div>
        {% endfor %}
    </div>
{% endblock %}
