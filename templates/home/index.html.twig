{% extends 'base.html.twig' %}

{% block title %}Home{% endblock %}

{% block body %}
    <div class="mb-8 grid gap-5 lg:grid-cols-3">
        <div class="rounded-2xl bg-gradient-to-br from-emerald-950 via-emerald-900 to-green-700 p-6 text-white shadow-lg lg:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">Meeting Management Dashboard</p>
            <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Welcome back, organizer.</h1>
            <p class="mt-3 max-w-2xl text-sm text-emerald-100">
                Keep your conferences and sessions organized in one place. Create new events, assign sessions, and manage registrations quickly.
            </p>
            <div class="mt-5 flex flex-wrap items-center gap-3">
                <a href="{{ path('conference_create') }}" class="rounded-lg bg-white px-4 py-2 text-sm font-semibold text-emerald-900 transition hover:bg-emerald-50">
                    + New Conference
                </a>
                <a href="{{ path('session_create') }}" class="rounded-lg border border-white/50 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10">
                    + New Session
                </a>
            </div>
        </div>
        <div class="rounded-2xl border border-emerald-200 bg-white p-6 shadow-sm">
            <p class="text-sm font-medium text-emerald-700">Total Conferences</p>
            <p class="mt-2 text-4xl font-bold text-emerald-950">{{ conferences|length }}</p>
            <p class="mt-2 text-sm text-emerald-700">Items currently scheduled</p>
        </div>
    </div>

    <div class="mb-4 flex items-center justify-between gap-3">
        <h2 class="text-xl font-bold text-emerald-950">Upcoming Conferences</h2>
        <a href="{{ path('conference_index') }}" class="text-sm font-semibold text-emerald-800 hover:text-emerald-950">View all</a>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {% for conference in conferences %}
            <article class="rounded-2xl border border-emerald-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
                <div class="mb-4 flex items-start justify-between gap-3">
                    <h3 class="text-lg font-semibold text-emerald-950">{{ conference.title }}</h3>
                    <span class="shrink-0 rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-800">
                        {{ conference.date ? conference.date|date('Y-m-d') : 'No date' }}
                    </span>
                </div>

                <p class="mb-4 min-h-10 text-sm text-emerald-800">
                    {{ conference.description }}
                </p>

                <div class="mb-5 rounded-xl bg-emerald-50 px-3 py-2 text-sm text-emerald-800">
                    <span class="font-semibold text-emerald-900">Location:</span> {{ conference.location }}
                </div>

                <a href="{{ path('conference_show', {id: conference.id}) }}" class="inline-flex items-center rounded-lg bg-emerald-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-emerald-800">
                    View Detail
                </a>
            </article>
        {% else %}
            <div class="col-span-full rounded-2xl border border-dashed border-emerald-300 bg-white p-10 text-center">
                <p class="text-sm text-emerald-800">No conferences found.</p>
                <a href="{{ path('conference_create') }}" class="mt-4 inline-flex items-center rounded-lg bg-emerald-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-800">
                    Create your first conference
                </a>
            </div>
        {% endfor %}
    </div>
{% endblock %}
