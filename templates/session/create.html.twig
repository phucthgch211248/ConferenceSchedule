{% extends 'base.html.twig' %}

{% block title %}Create Session{% endblock %}

{% block body %}
    <div class="mx-auto w-full max-w-3xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-emerald-950">Create Session</h1>
            <p class="text-sm text-emerald-700">Add a new session for a conference.</p>
        </div>

        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" class="space-y-5 rounded-2xl border border-emerald-200 bg-white p-6 shadow-sm">
            <div>
                <label for="title" class="mb-1 block text-sm font-medium text-emerald-800">Title</label>
                <input id="title" name="title" type="text" required class="w-full rounded-lg border border-emerald-300 px-3 py-2.5 text-sm text-emerald-900 outline-none ring-emerald-600 focus:ring-2">
            </div>

            <div>
                <label for="conferenceId" class="mb-1 block text-sm font-medium text-emerald-800">Conference</label>
                <select id="conferenceId" name="conferenceId" required class="w-full rounded-lg border border-emerald-300 bg-white px-3 py-2.5 text-sm text-emerald-900 outline-none ring-emerald-600 focus:ring-2">
                    <option value="">Select conference</option>
                    {% for conference in conferences %}
                        <option value="{{ conference.id }}">{{ conference.title }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                    <label for="startTime" class="mb-1 block text-sm font-medium text-emerald-800">Start Time</label>
                    <input id="startTime" name="startTime" type="datetime-local" required class="w-full rounded-lg border border-emerald-300 px-3 py-2.5 text-sm text-emerald-900 outline-none ring-emerald-600 focus:ring-2">
                </div>

                <div>
                    <label for="endTime" class="mb-1 block text-sm font-medium text-emerald-800">End Time</label>
                    <input id="endTime" name="endTime" type="datetime-local" required class="w-full rounded-lg border border-emerald-300 px-3 py-2.5 text-sm text-emerald-900 outline-none ring-emerald-600 focus:ring-2">
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="rounded-lg bg-emerald-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-800">
                    Save
                </button>
                <a href="{{ path('session_index') }}" class="rounded-lg border border-emerald-300 px-4 py-2 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-50">
                    Cancel
                </a>
            </div>
        </form>
    </div>
{% endblock %}
