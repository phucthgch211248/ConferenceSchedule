{% extends 'base.html.twig' %}

{% block title %}Create Session{% endblock %}

{% block body %}
    <div class="mx-auto w-full max-w-3xl">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-slate-900">Create Session</h1>
            <p class="text-sm text-slate-500">Add a new session for a conference.</p>
        </div>

        {% for message in app.flashes('error') %}
            <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div>
                <label for="title" class="mb-1 block text-sm font-medium text-slate-700">Title</label>
                <input id="title" name="title" type="text" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
            </div>

            <div>
                <label for="conferenceId" class="mb-1 block text-sm font-medium text-slate-700">Conference</label>
                <select id="conferenceId" name="conferenceId" required class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
                    <option value="">Select conference</option>
                    {% for conference in conferences %}
                        <option value="{{ conference.id }}">{{ conference.title }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                <div>
                    <label for="startTime" class="mb-1 block text-sm font-medium text-slate-700">Start Time</label>
                    <input id="startTime" name="startTime" type="datetime-local" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
                </div>

                <div>
                    <label for="endTime" class="mb-1 block text-sm font-medium text-slate-700">End Time</label>
                    <input id="endTime" name="endTime" type="datetime-local" required class="w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-800 outline-none ring-indigo-500 focus:ring-2">
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3 pt-2">
                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">
                    Save
                </button>
                <a href="{{ path('session_index') }}" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Cancel
                </a>
            </div>
        </form>
    </div>
{% endblock %}
